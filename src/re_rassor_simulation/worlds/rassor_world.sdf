<?xml version="1.0" ?>
<!--
  RE-RASSOR Simulation World (Gazebo Harmonic / SDF 1.10)

  Robot geometry:
    Body:   0.6 × 0.6 × 0.25 m box, center at z=0.325 m (bottom z=0.20 m)
    Wheels: 4 × cylinder r=0.10 m, w=0.08 m
            FL=(+0.20,+0.35,0.10)  FR=(+0.20,-0.35,0.10)
            RL=(-0.20,+0.35,0.10)  RR=(-0.20,-0.35,0.10)
    Drive:  DiffDrive with 4 joints → effective skid steer
    Camera: depth camera on top-center of body, facing forward
            camera_link=(0.0, 0.0, 0.52) in model frame

  TF tree:
    odom → base_footprint  (DiffDrive plugin)
    base_footprint → base_link → camera_link  (robot_state_publisher)

  Camera topics bridged to ROS:
    /camera/image        → /camera/color/image_raw
    /camera/depth_image  → /camera/depth/image_raw
    /camera/points       → /camera/depth/points
    /camera/camera_info  → /camera/color/camera_info + /camera/depth/camera_info
-->
<sdf version="1.10">
  <world name="rassor_world">

    <!-- ================================================================
         WORLD PLUGINS
         ================================================================ -->
    <plugin filename="gz-sim-physics-system"
            name="gz::sim::systems::Physics"/>
    <plugin filename="gz-sim-user-commands-system"
            name="gz::sim::systems::UserCommands"/>
    <plugin filename="gz-sim-scene-broadcaster-system"
            name="gz::sim::systems::SceneBroadcaster"/>
    <plugin filename="gz-sim-sensors-system"
            name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>

    <physics name="default_physics" type="ode">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
    </physics>

    <!-- ================================================================
         LIGHTING
         ================================================================ -->
    <light name="sun" type="directional">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.9 0.9 0.9 1</diffuse>
      <specular>0.3 0.3 0.3 1</specular>
      <direction>-0.5 0.1 -0.9</direction>
      <attenuation>
        <range>1000</range>
        <constant>0.9</constant>
        <linear>0.01</linear>
        <quadratic>0.001</quadratic>
      </attenuation>
    </light>

    <!-- ================================================================
         GROUND PLANE
         ================================================================ -->
    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry>
            <plane><normal>0 0 1</normal><size>50 50</size></plane>
          </geometry>
          <surface>
            <friction>
              <ode><mu>1.0</mu><mu2>1.0</mu2></ode>
            </friction>
          </surface>
        </collision>
        <visual name="visual">
          <geometry>
            <plane><normal>0 0 1</normal><size>50 50</size></plane>
          </geometry>
          <material>
            <ambient>0.7 0.7 0.7 1</ambient>
            <diffuse>0.7 0.7 0.7 1</diffuse>
            <specular>0.01 0.01 0.01 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- ================================================================
         OBSTACLES
         ================================================================ -->
    <model name="obstacle_1">
      <static>true</static>
      <pose>3.0 0.0 0.25 0 0 0</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>0.5 0.5 0.5</size></box></geometry></collision>
        <visual name="vis">
          <geometry><box><size>0.5 0.5 0.5</size></box></geometry>
          <material><ambient>1.0 0.3 0.0 1</ambient><diffuse>1.0 0.3 0.0 1</diffuse></material>
        </visual>
      </link>
    </model>

    <model name="obstacle_2">
      <static>true</static>
      <pose>-2.0 2.0 0.25 0 0 0</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>0.5 0.5 0.5</size></box></geometry></collision>
        <visual name="vis">
          <geometry><box><size>0.5 0.5 0.5</size></box></geometry>
          <material><ambient>0.0 0.3 1.0 1</ambient><diffuse>0.0 0.3 1.0 1</diffuse></material>
        </visual>
      </link>
    </model>

    <model name="obstacle_3">
      <static>true</static>
      <pose>0.0 3.0 0.25 0 0 0</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>0.5 1.0 0.5</size></box></geometry></collision>
        <visual name="vis">
          <geometry><box><size>0.5 1.0 0.5</size></box></geometry>
          <material><ambient>0.0 0.8 0.2 1</ambient><diffuse>0.0 0.8 0.2 1</diffuse></material>
        </visual>
      </link>
    </model>

    <model name="obstacle_4">
      <static>true</static>
      <pose>2.5 2.5 0.35 0 0 0.785</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>0.4 0.8 0.7</size></box></geometry></collision>
        <visual name="vis">
          <geometry><box><size>0.4 0.8 0.7</size></box></geometry>
          <material><ambient>0.8 0.0 0.8 1</ambient><diffuse>0.8 0.0 0.8 1</diffuse></material>
        </visual>
      </link>
    </model>
    <!-- AFTER obstacle_4, BEFORE the rassor model, ADD these 4 walls: -->

    <model name="wall_north">
      <static>true</static>
      <pose>0.0 8.0 0.5 0 0 0</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>16.0 0.2 1.0</size></box></geometry></collision>
        <visual name="vis">
          <geometry><box><size>16.0 0.2 1.0</size></box></geometry>
          <material><ambient>0.6 0.5 0.4 1</ambient><diffuse>0.6 0.5 0.4 1</diffuse></material>
        </visual>
      </link>
    </model>

    <model name="wall_south">
      <static>true</static>
      <pose>0.0 -8.0 0.5 0 0 0</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>16.0 0.2 1.0</size></box></geometry></collision>
        <visual name="vis">
          <geometry><box><size>16.0 0.2 1.0</size></box></geometry>
          <material><ambient>0.6 0.5 0.4 1</ambient><diffuse>0.6 0.5 0.4 1</diffuse></material>
        </visual>
      </link>
    </model>

    <model name="wall_east">
      <static>true</static>
      <pose>8.0 0.0 0.5 0 0 0</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>0.2 16.0 1.0</size></box></geometry></collision>
        <visual name="vis">
          <geometry><box><size>0.2 16.0 1.0</size></box></geometry>
          <material><ambient>0.6 0.5 0.4 1</ambient><diffuse>0.6 0.5 0.4 1</diffuse></material>
        </visual>
      </link>
    </model>

    <model name="wall_west">
      <static>true</static>
      <pose>-8.0 0.0 0.5 0 0 0</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>0.2 16.0 1.0</size></box></geometry></collision>
        <visual name="vis">
          <geometry><box><size>0.2 16.0 1.0</size></box></geometry>
          <material><ambient>0.6 0.5 0.4 1</ambient><diffuse>0.6 0.5 0.4 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- ================================================================
         RE-RASSOR ROBOT  —  4-wheel skid steer, depth camera on top
         ================================================================
         Model-frame dimensions:
           Body (0.6×0.6×0.25 m):  bottom z=0.20, centre z=0.325, top z=0.45
           Wheels (r=0.10 m):       centre z=0.10
           Camera:                  z=0.52 (above body top), centred, facing fwd
    -->
    <model name="rassor">
      <pose>0 0 0 0 0 0</pose>

      <!-- ── base_footprint (ground reference, massless) ── -->
      <link name="base_footprint">
        <pose>0 0 0 0 0 0</pose>
        <inertial>
          <mass>0.001</mass>
          <inertia>
            <ixx>1e-6</ixx><ixy>0</ixy><ixz>0</ixz>
            <iyy>1e-6</iyy><iyz>0</iyz><izz>1e-6</izz>
          </inertia>
        </inertial>
      </link>

      <!-- ── base_link (main body) ── -->
      <link name="base_link">
        <pose>0 0 0.325 0 0 0</pose>
        <inertial>
          <mass>15.0</mass>
          <inertia>
            <ixx>0.4922</ixx><ixy>0</ixy><ixz>0</ixz>
            <iyy>0.4922</iyy><iyz>0</iyz><izz>0.9000</izz>
          </inertia>
        </inertial>
        <collision name="base_col">
          <geometry><box><size>0.6 0.6 0.25</size></box></geometry>
        </collision>
        <visual name="base_vis">
          <geometry><box><size>0.6 0.6 0.25</size></box></geometry>
          <material>
            <ambient>0.35 0.35 0.40 1</ambient>
            <diffuse>0.35 0.35 0.40 1</diffuse>
            <specular>0.1 0.1 0.1 1</specular>
          </material>
        </visual>
      </link>

      <joint name="base_footprint_joint" type="fixed">
        <parent>base_footprint</parent>
        <child>base_link</child>
      </joint>

      <!-- ── Wheel macro (cylinder, axis in global Y) ──
           All 4 wheels are identical except for pose.
           Cylinder default spin axis = local Z.
           Rotate -90° about X so local Z → global Y (roll direction).
      -->

      <!-- Front-Left wheel -->
      <link name="front_left_wheel">
        <pose>0.20 0.35 0.10 -1.5707963 0 0</pose>
        <inertial>
          <mass>1.5</mass>
          <inertia>
            <ixx>0.0075</ixx><ixy>0</ixy><ixz>0</ixz>
            <iyy>0.0075</iyy><iyz>0</iyz><izz>0.0075</izz>
          </inertia>
        </inertial>
        <collision name="col">
          <geometry><cylinder><radius>0.10</radius><length>0.08</length></cylinder></geometry>
          <surface><friction><ode><mu>2.0</mu><mu2>2.0</mu2></ode></friction></surface>
        </collision>
        <visual name="vis">
          <geometry><cylinder><radius>0.10</radius><length>0.08</length></cylinder></geometry>
          <material><ambient>0.1 0.1 0.1 1</ambient><diffuse>0.1 0.1 0.1 1</diffuse></material>
        </visual>
      </link>
      <joint name="front_left_wheel_joint" type="revolute">
        <parent>base_link</parent>
        <child>front_left_wheel</child>
        <axis>
          <xyz expressed_in="__model__">0 1 0</xyz>
          <dynamics><damping>0.05</damping><friction>0.05</friction></dynamics>
          <limit><lower>-1e16</lower><upper>1e16</upper></limit>
        </axis>
      </joint>

      <!-- Front-Right wheel -->
      <link name="front_right_wheel">
        <pose>0.20 -0.35 0.10 -1.5707963 0 0</pose>
        <inertial>
          <mass>1.5</mass>
          <inertia>
            <ixx>0.0075</ixx><ixy>0</ixy><ixz>0</ixz>
            <iyy>0.0075</iyy><iyz>0</iyz><izz>0.0075</izz>
          </inertia>
        </inertial>
        <collision name="col">
          <geometry><cylinder><radius>0.10</radius><length>0.08</length></cylinder></geometry>
          <surface><friction><ode><mu>2.0</mu><mu2>2.0</mu2></ode></friction></surface>
        </collision>
        <visual name="vis">
          <geometry><cylinder><radius>0.10</radius><length>0.08</length></cylinder></geometry>
          <material><ambient>0.1 0.1 0.1 1</ambient><diffuse>0.1 0.1 0.1 1</diffuse></material>
        </visual>
      </link>
      <joint name="front_right_wheel_joint" type="revolute">
        <parent>base_link</parent>
        <child>front_right_wheel</child>
        <axis>
          <xyz expressed_in="__model__">0 1 0</xyz>
          <dynamics><damping>0.05</damping><friction>0.05</friction></dynamics>
          <limit><lower>-1e16</lower><upper>1e16</upper></limit>
        </axis>
      </joint>

      <!-- Rear-Left wheel -->
      <link name="rear_left_wheel">
        <pose>-0.20 0.35 0.10 -1.5707963 0 0</pose>
        <inertial>
          <mass>1.5</mass>
          <inertia>
            <ixx>0.0075</ixx><ixy>0</ixy><ixz>0</ixz>
            <iyy>0.0075</iyy><iyz>0</iyz><izz>0.0075</izz>
          </inertia>
        </inertial>
        <collision name="col">
          <geometry><cylinder><radius>0.10</radius><length>0.08</length></cylinder></geometry>
          <surface><friction><ode><mu>2.0</mu><mu2>2.0</mu2></ode></friction></surface>
        </collision>
        <visual name="vis">
          <geometry><cylinder><radius>0.10</radius><length>0.08</length></cylinder></geometry>
          <material><ambient>0.1 0.1 0.1 1</ambient><diffuse>0.1 0.1 0.1 1</diffuse></material>
        </visual>
      </link>
      <joint name="rear_left_wheel_joint" type="revolute">
        <parent>base_link</parent>
        <child>rear_left_wheel</child>
        <axis>
          <xyz expressed_in="__model__">0 1 0</xyz>
          <dynamics><damping>0.05</damping><friction>0.05</friction></dynamics>
          <limit><lower>-1e16</lower><upper>1e16</upper></limit>
        </axis>
      </joint>

      <!-- Rear-Right wheel -->
      <link name="rear_right_wheel">
        <pose>-0.20 -0.35 0.10 -1.5707963 0 0</pose>
        <inertial>
          <mass>1.5</mass>
          <inertia>
            <ixx>0.0075</ixx><ixy>0</ixy><ixz>0</ixz>
            <iyy>0.0075</iyy><iyz>0</iyz><izz>0.0075</izz>
          </inertia>
        </inertial>
        <collision name="col">
          <geometry><cylinder><radius>0.10</radius><length>0.08</length></cylinder></geometry>
          <surface><friction><ode><mu>2.0</mu><mu2>2.0</mu2></ode></friction></surface>
        </collision>
        <visual name="vis">
          <geometry><cylinder><radius>0.10</radius><length>0.08</length></cylinder></geometry>
          <material><ambient>0.1 0.1 0.1 1</ambient><diffuse>0.1 0.1 0.1 1</diffuse></material>
        </visual>
      </link>
      <joint name="rear_right_wheel_joint" type="revolute">
        <parent>base_link</parent>
        <child>rear_right_wheel</child>
        <axis>
          <xyz expressed_in="__model__">0 1 0</xyz>
          <dynamics><damping>0.05</damping><friction>0.05</friction></dynamics>
          <limit><lower>-1e16</lower><upper>1e16</upper></limit>
        </axis>
      </joint>

      <!-- ── Camera link — on top, centred, facing forward ── -->
      <!--
        body top = z=0.45 m;  camera_link at z=0.52 m (0.07 m above body top).
        Small box visual represents the Astra depth camera housing.
        Sensor is forward-facing (no rotation needed for +X=forward convention).
      -->
      <link name="camera_link">
        <pose>0.0 0 0.52 0 0 0</pose>
        <inertial>
          <mass>0.15</mass>
          <inertia>
            <ixx>1e-4</ixx><ixy>0</ixy><ixz>0</ixz>
            <iyy>1e-4</iyy><iyz>0</iyz><izz>1e-4</izz>
          </inertia>
        </inertial>
        <visual name="vis">
          <!-- Astra-like housing: 0.165 wide × 0.030 tall × 0.025 deep -->
          <geometry><box><size>0.025 0.165 0.030</size></box></geometry>
          <material>
            <ambient>0.05 0.05 0.05 1</ambient>
            <diffuse>0.05 0.05 0.05 1</diffuse>
          </material>
        </visual>

        <!-- ── RGBD Camera Sensor ── -->
        <sensor name="rgbd_camera" type="rgbd_camera">
          <camera>
            <horizontal_fov>1.04719755</horizontal_fov>  <!-- 60° -->
            <image>
              <width>640</width>
              <height>480</height>
              <format>R8G8B8</format>
            </image>
            <clip>
              <near>0.10</near>
              <far>8.00</far>
            </clip>
            <noise>
              <type>gaussian</type>
              <mean>0.0</mean>
              <stddev>0.005</stddev>
            </noise>
            <lens>
              <intrinsics>
                <fx>554.25</fx>
                <fy>554.25</fy>
                <cx>320.5</cx>
                <cy>240.5</cy>
                <s>0</s>
              </intrinsics>
            </lens>
          </camera>
          <always_on>true</always_on>
          <update_rate>15</update_rate>
          <visualize>false</visualize>
          <topic>/camera</topic>
        </sensor>
      </link>

      <joint name="camera_joint" type="fixed">
        <parent>base_link</parent>
        <child>camera_link</child>
      </joint>

      <!-- ================================================================
           MODEL PLUGINS
           ================================================================ -->

      <!--
        DiffDrive with 4 wheel joints = skid-steer behaviour.
        Left side: front_left + rear_left
        Right side: front_right + rear_right
        /cmd_vel angular.z drives differential between sides.
      -->
      <plugin filename="gz-sim-diff-drive-system"
              name="gz::sim::systems::DiffDrive">
        <left_joint>front_left_wheel_joint</left_joint>
        <left_joint>rear_left_wheel_joint</left_joint>
        <right_joint>front_right_wheel_joint</right_joint>
        <right_joint>rear_right_wheel_joint</right_joint>
        <wheel_separation>0.70</wheel_separation>
        <wheel_radius>0.10</wheel_radius>
        <odom_publish_frequency>30</odom_publish_frequency>
        <topic>/cmd_vel</topic>
        <odom_topic>/odometry/gz_wheel</odom_topic>
        <tf_topic>/tf_gz_unused</tf_topic>
        <publish_tf>false</publish_tf>
        <frame_id>odom</frame_id>
        <child_frame_id>base_footprint</child_frame_id>
        <min_velocity>-0.30</min_velocity>
        <max_velocity>0.30</max_velocity>
        <min_acceleration>-1.0</min_acceleration>
        <max_acceleration>1.0</max_acceleration>
      </plugin>

      <plugin filename="gz-sim-joint-state-publisher-system"
              name="gz::sim::systems::JointStatePublisher">
        <topic>/joint_states</topic>
        <joint_name>front_left_wheel_joint</joint_name>
        <joint_name>front_right_wheel_joint</joint_name>
        <joint_name>rear_left_wheel_joint</joint_name>
        <joint_name>rear_right_wheel_joint</joint_name>
      </plugin>

    </model><!-- end rassor -->

  </world>
</sdf>
