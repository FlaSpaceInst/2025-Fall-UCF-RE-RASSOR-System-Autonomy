<?xml version="1.0" ?>
<model>
  <name>rassor_astra</name>
  <version>1.0</version>
  <sdf version="1.6">model.sdf</sdf>
  <author>
    <name>RE-RASSOR Team</name>
    <email>todo@ucf.edu</email>
  </author>
  <description>
    Minimal RE-RASSOR chassis with an Astra Pro 3D depth camera Gazebo
    sensor (libgazebo_ros_depth_camera.so).  Used by re_rassor_test for
    end-to-end obstacle detection simulation.

    Camera intrinsics (640x480, 60-degree HFOV):
      fx = fy = 554.26,  cx = 320,  cy = 240
    Depth range: 0.3 m – 8.0 m
    Mount: +0.15 m forward, +0.10 m up, 5-degree downward pitch
  </description>
</model>
